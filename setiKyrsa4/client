#include <iostream>
#include <string>
#include <cstring>
#include <sstream>
#include <vector>

#include <sys/socket.h>
#include <sys/types.h>
#include <sys/select.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <netdb.h>
#include <unistd.h>
#include <errno.h>

#define PORT 3333
#define SERVER_ADDR "127.0.0.1"
#define BUFFER_SIZE 1024

using namespace std;

enum State {
    STATE_DISCONNECTED,
    STATE_CONNECTING,
    STATE_WAITING_COMMAND,
    STATE_CONVERTING,
    STATE_DISCONNECTING
};

class TCPClient {
private:
    int sock;
    State currentState;
    string allowedBases;
    
    bool SendMsg(const string& msg) {
        if (sock < 0) return false;
        string data = msg + "\n";
        int result = send(sock, data.c_str(), data.length(), 0);
        if (result == -1) {
            cerr << "[ОШИБКА] send(): " << strerror(errno) << endl;
            return false;
        }
        return true;
    }
    
    string RecvMsg() {
        if (sock < 0) return "";
        char buffer[BUFFER_SIZE];
        memset(buffer, 0, BUFFER_SIZE);
        int bytes = recv(sock, buffer, BUFFER_SIZE - 1, 0);
        if (bytes <= 0) {
            if (bytes == 0) {
                cout << "[INFO] Сервер закрыл соединение" << endl;
            } else {
                cerr << "[ОШИБКА] recv(): " << strerror(errno) << endl;
            }
            return "";
        }
        string msg(buffer);
        while (!msg.empty() && (msg.back() == '\n' || msg.back() == '\r')) {
            msg.pop_back();
        }
        return msg;
    }
    
    string ConvertToBase(int number, int base) {
        if (number == 0) return "0";
        const char digits[] = "0123456789ABCDEF";
        string result;
        int num = number;
        while (num > 0) {
            result = digits[num % base] + result;
            num /= base;
        }
        return result;
    }
    
    void ConvertNumber(int number) {
        cout << "\n========== РЕЗУЛЬТАТ ПЕРЕВОДА ==========" << endl;
        cout << "Число: " << number << endl;
        cout << "Разрешенные системы: " << allowedBases << endl;
        cout << "----------------------------------------" << endl;
        
        stringstream ss(allowedBases);
        string baseStr;
        while (getline(ss, baseStr, ',')) {
            int base = stoi(baseStr);
            string result = ConvertToBase(number, base);
            cout << "  Система " << base << ": " << result << endl;
        }
        cout << "========================================\n" << endl;
    }
    
    bool SyncSettings() {
        cout << "[КЛИЕНТ] Синхронизация настроек..." << endl;
        if (!SendMsg("GET_CONFIG")) {
            return false;
        }
        
        string response = RecvMsg();
        if (response.empty()) {
            return false;
        }
        
        cout << "[СЕРВЕР] " << response << endl;
        
        if (response.substr(0, 2) == "OK") {
            size_t basesPos = response.find("BASES:");
            if (basesPos != string::npos) {
                allowedBases = response.substr(basesPos + 6);
                cout << "[КЛИЕНТ] Настройки получены: " << allowedBases << endl;
                return true;
            }
        } else if (response.substr(0, 5) == "ERROR") {
            cerr << "[ОШИБКА] " << response << endl;
            return false;
        }
        return false;
    }
    
    void RequestConvert(int number) {
        // Синхронизация перед каждой операцией
        if (!SyncSettings()) {
            cerr << "[ОШИБКА] Не удалось синхронизировать настройки" << endl;
            currentState = STATE_WAITING_COMMAND;
            return;
        }
        
        string request = "CONVERT:" + to_string(number);
        if (!SendMsg(request)) {
            currentState = STATE_WAITING_COMMAND;
            return;
        }
        
        currentState = STATE_CONVERTING;
        
        string response = RecvMsg();
        if (response.empty()) {
            currentState = STATE_DISCONNECTED;
            return;
        }
        
        cout << "[СЕРВЕР] " << response << endl;
        
        if (response == "OK:PROCEED") {
            ConvertNumber(number);
            currentState = STATE_WAITING_COMMAND;
        } else if (response.substr(0, 4) == "OK:CONFIG_UPDATED") {
            size_t colonPos = response.find(':');
            if (colonPos != string::npos) {
                allowedBases = response.substr(colonPos + 1);
                cout << "[КЛИЕНТ] Настройки обновлены сервером: " << allowedBases << endl;
            }
            ConvertNumber(number);
            currentState = STATE_WAITING_COMMAND;
        } else if (response == "ERROR:INVALID_NUMBER") {
            cerr << "[ОШИБКА] Неверный формат числа" << endl;
            currentState = STATE_WAITING_COMMAND;
        } else {
            cerr << "[ОШИБКА] Неизвестный ответ: " << response << endl;
            currentState = STATE_WAITING_COMMAND;
        }
    }
    
    void HandleUserInput() {
        static bool promptShown = false;
        
        if (!promptShown) {
            cout << "\n========== КОМАНДЫ ==========" << endl;
            cout << "Разрешено: " << allowedBases << endl;
            cout << "Формат: <число>" << endl;
            cout << "Пример: 42" << endl;
            cout << "Команды: settings, exit" << endl;
            cout << "==============================" << endl;
            cout << "> " << flush;
            promptShown = true;
        }
        
        fd_set readSet;
        FD_ZERO(&readSet);
        FD_SET(0, &readSet);
        struct timeval tv;
        tv.tv_sec = 0;
        tv.tv_usec = 0;
        
        if (select(1, &readSet, nullptr, nullptr, &tv) > 0) {
            string input;
            getline(cin, input);
            promptShown = false;
            
            if (input == "exit" || input == "quit") {
                Disconnect();
                return;
            } else if (input == "settings") {
                cout << "\nТекущие настройки:" << endl;
                cout << "  Разрешенные системы: " << allowedBases << endl;
                return;
            }
            
            try {
                int number = stoi(input);
                RequestConvert(number);
            } catch (...) {
                cerr << "[ОШИБКА] Неверный формат. Введите число." << endl;
            }
        }
    }
    
public:
    TCPClient() : sock(-1), currentState(STATE_DISCONNECTED), allowedBases("") {}
    
    ~TCPClient() {
        Disconnect();
    }
    
    bool Connect(const string& serverIp = SERVER_ADDR, int port = PORT) {
        if (currentState != STATE_DISCONNECTED) {
            cerr << "[ОШИБКА] Клиент уже запущен" << endl;
            return false;
        }
        
        sock = socket(AF_INET, SOCK_STREAM, 0);
        if (sock == -1) {
            cerr << "[ОШИБКА] socket(): " << strerror(errno) << endl;
            return false;
        }
        
        sockaddr_in serverAddr;
        memset(&serverAddr, 0, sizeof(serverAddr));
        serverAddr.sin_family = AF_INET;
        serverAddr.sin_port = htons(port);
        
        if (inet_addr(serverIp.c_str()) == INADDR_NONE) {
            hostent* host = gethostbyname(serverIp.c_str());
            if (host == nullptr) {
                cerr << "[ОШИБКА] Неверный адрес: " << serverIp << endl;
                close(sock);
                sock = -1;
                return false;
            }
            memcpy(&serverAddr.sin_addr, host->h_addr, host->h_length);
        } else {
            serverAddr.sin_addr.s_addr = inet_addr(serverIp.c_str());
        }
        
        if (::connect(sock, (sockaddr*)&serverAddr, sizeof(serverAddr)) == -1) {
            cerr << "[ОШИБКА] connect(): " << strerror(errno) << endl;
            close(sock);
            sock = -1;
            return false;
        }
        
        cout << "[КЛИЕНТ] Подключение к " << serverIp << ":" << port << endl;
        
        // Ждем приветствия от сервера (сервер отправляет настройки сразу)
        string response = RecvMsg();
        if (response.empty()) {
            cerr << "[ОШИБКА] Сервер не ответил" << endl;
            close(sock);
            sock = -1;
            return false;
        }
        
        cout << "[СЕРВЕР] " << response << endl;
        
        if (response.substr(0, 2) == "OK") {
            size_t basesPos = response.find("BASES:");
            if (basesPos != string::npos) {
                allowedBases = response.substr(basesPos + 6);
                cout << "[КЛИЕНТ] Настройки получены: " << allowedBases << endl;
                currentState = STATE_WAITING_COMMAND;
                return true;
            }
        } else if (response == "ERROR:ACCESS_DENIED") {
            cerr << "[ОШИБКА] Доступ запрещен" << endl;
            close(sock);
            sock = -1;
            return false;
        }
        
        return false;
    }
    
    void Disconnect() {
        if (sock >= 0 && currentState != STATE_DISCONNECTED) {
            SendMsg("DISCONNECT");
            usleep(100000);
            close(sock);
            sock = -1;
        }
        currentState = STATE_DISCONNECTED;
        cout << "[КЛИЕНТ] Отключено" << endl;
    }
    
    void Run() {
        while (currentState != STATE_DISCONNECTED) {
            if (currentState == STATE_WAITING_COMMAND) {
                HandleUserInput();
            } else if (currentState == STATE_CONVERTING) {
                usleep(10000);
            } else {
                usleep(10000);
            }
        }
    }
};

int main() {
    cout << "========================================" << endl;
    cout << "   TCP КЛИЕНТ - ПЕРЕВОД ЧИСЕЛ" << endl;
    cout << "   Студент: Бусыгин Г.С." << endl;
    cout << "   Группа: 23ПТ1" << endl;
    cout << "========================================" << endl;
    
    TCPClient client;
    
    if (client.Connect()) {
        client.Run();
    } else {
        cerr << "[ОШИБКА] Не удалось подключиться к серверу" << endl;
        return 1;
    }
    
    return 0;
}

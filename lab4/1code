#include <iostream>
#include <iomanip>
#include <cstdint>
using namespace std;

// Функция раунда шифрования
void round_encrypt(volatile uint32_t* a0, volatile uint32_t* a1,
                   const volatile uint32_t* roundKey,
                   const volatile uint8_t S[4][256]) {
    if (a0 == nullptr || a1 == nullptr || roundKey == nullptr || S == nullptr) {
        return;
    }
    
    // Сложение с раундовым ключом по модулю 2^32
    volatile uint32_t summ = (*a0) + (*roundKey);
    
    // Подстановка через 4 таблицы по 256 байт
    volatile uint32_t temp = 0; //врем перемен для резов  ( чтобы компилятор не оптимизировал)
    temp |= (uint32_t)S[0][(summ >> 0) & 0xFF] << 0; (берется млбайт замен по табоицк с0 и объединяется с темп через ор)
    temp |= (uint32_t)S[1][(summ >> 8) & 0xFF] << 8;
    temp |= (uint32_t)S[2][(summ >> 16) & 0xFF] << 16;
    temp |= (uint32_t)S[3][(summ >> 24) & 0xFF] << 24;
    
    // Циклический сдвиг влево на 11 бит
    volatile uint32_t sdvig = (temp << 11) | (temp >> (32 - 11)); (сдвиг влево на 11(0-20 едут на 11-31) , потом вправо на 21 бит ) все это объединяется и получается крч сдвиг 
    
    // XOR с левым подблоком
    uint32_t result = *a1 ^ sdvig; иксор если правильно это искл или , оно тут для того чтобы смешать левую и правую чать , чтобы шифр стал жоско не легким , потом чтобы норм расшифр и левая половина зависит от правой
    
    // Обмен подблоков
    *a1 = *a0; ( * - указатель на переменную , ссылатеся по адресу) тут запись новая лева = старая правая 
    *a0 = result; новая правая это результат 28 строчки хора 
}

int main() {
    // Таблицы замены π0-π7 (из ГОСТ)
    const uint8_t pi[8][16] = {
        {12, 4, 6, 2, 10, 5, 11, 9, 14, 8, 13, 7, 0, 3, 15, 1},
        {6, 8, 2, 3, 9, 10, 5, 12, 1, 14, 4, 7, 11, 13, 0, 15},
        {11, 3, 5, 8, 2, 15, 10, 13, 14, 1, 7, 4, 12, 9, 6, 0},
        {12, 8, 2, 1, 13, 4, 15, 6, 7, 0, 10, 5, 3, 14, 9, 11},
        {7, 15, 5, 10, 8, 1, 6, 13, 0, 9, 3, 14, 11, 4, 2, 12},
        {5, 13, 15, 6, 9, 2, 12, 10, 11, 7, 8, 1, 4, 3, 14, 0},
        {8, 14, 2, 5, 6, 9, 1, 12, 15, 4, 11, 0, 13, 10, 3, 7},
        {1, 7, 14, 13, 0, 5, 8, 3, 4, 15, 10, 6, 9, 12, 11, 2}
    };
    
    // Формирование 4 таблиц S по 256 байт
    volatile uint8_t S[4][256];
    for (int i = 0; i < 256; i++) {
        uint8_t high = (i >> 4) & 0x0F;
        uint8_t low = i & 0x0F;
        S[0][i] = (pi[1][high] << 4) | pi[0][low];
        S[1][i] = (pi[3][high] << 4) | pi[2][low];
        S[2][i] = (pi[5][high] << 4) | pi[4][low];
        S[3][i] = (pi[7][high] << 4) | pi[6][low];
    }
    
    // Тестовый ключ 256 бит (из ГОСТ)
    volatile uint32_t testKey[8] = {
        0xffeeddcc, 0xbbaa9988, 0x77665544, 0x33221100,
        0xf0f1f2f3, 0xf4f5f6f7, 0xf8f9fafb, 0xfcfdfeff
    };
    
    // Развертывание итерационных ключей
    volatile uint32_t iterativeKey[32] = {0};
    
    // Первые 24 раундовых ключа (прямой порядок)
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 8; j++) {
            iterativeKey[j + 8 * i] = testKey[j];
        }
    }
    
    // Последние 8 раундовых ключа (обратный порядок)
    for (int i = 0; i < 8; i++) {
        iterativeKey[i + 24] = testKey[7 - i];
    }
    
    // Открытый текст fedcba9876543210
    volatile uint64_t a = 0xfedcba9876543210;
    volatile uint32_t a1 = (a >> 32);  // старшие 32 бита
    volatile uint32_t a0 = (a & 0xFFFFFFFF);  // младшие 32 бита
    
    cout << "Исходный текст: " << hex << a << endl;
    cout << "A1=" << a1 << " A0=" << a0 << endl << endl;
    
    // Зашифрование (32 раунда)
    for (int i = 0; i < 32; i++) {
        round_encrypt(&a0, &a1, &iterativeKey[i], S);
        cout << "Раунд " << dec << (i + 1) << ": A1=" << hex << a1 << " A0=" << a0 << endl;
    }
    
    uint64_t cipherText = ((uint64_t)a0 << 32) | a1;
    cout << "\nШифртекст: " << hex << cipherText << endl;
    
    // Расшифрование
    cout << "\n--- РАСШИФРОВАНИЕ ---" << endl;
    volatile uint64_t b = cipherText;
    volatile uint32_t b1 = (b >> 32);
    volatile uint32_t b0 = (b & 0xFFFFFFFF);
    
    for (int i = 31; i >= 0; i--) {
        round_encrypt(&b0, &b1, &iterativeKey[i], S);
        cout << "Раунд " << dec << (32 - i) << ": B1=" << hex << b1 << " B0=" << b0 << endl;
    }
    
    volatile uint32_t tmp = b0;
    b0 = b1;
    b1 = tmp;
    
    uint64_t decryptText = ((uint64_t)b1 << 32) | b0;
    cout << "\nРасшифрованный текст: " << hex << decryptText << endl;
    
    return 0;
}

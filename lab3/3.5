#include <iostream>
#include <fstream>
#include <string>
#include <cstdint>
using namespace std;

// Функция из пункта 3.4
uint8_t komb(uint8_t x, const uint8_t S[16], int p) {
    uint8_t x1 = (x >> 4) & 0x0F;
    uint8_t x2 = x & 0x0F;
    uint8_t y1 = S[x1];
    uint8_t y2 = S[x2];
    uint8_t xy = (y1 << 4) | y2;
    uint8_t result = (xy >> p) | (xy << (8 - p));
    return result;
}

int main() {
    // Таблица замены S для варианта 4
    uint8_t S[16] = {
        0x0C, 0x08, 0x02, 0x01, 0x0D, 0x04, 0x0F, 0x06,
        0x07, 0x00, 0x0A, 0x05, 0x03, 0x0E, 0x09, 0x0B
    };
    int p = 3;
    
    cout << "Введите имя файла: ";
    string filename;
    cin >> filename;
    
    string output = filename + "_encoded";
    
    ifstream infile(filename, ios::binary);
    ofstream outfile(output, ios::binary);
    
    if(!infile.is_open() || !outfile.is_open()) {
        cerr << "Ошибка открытия файлов!" << endl;
        return 1;
    }
    
    uint8_t buffer = 0;
    while(infile.read(reinterpret_cast<char*>(&buffer), sizeof(buffer))) {
        buffer = komb(buffer, S, p);
        outfile.write(reinterpret_cast<char*>(&buffer), sizeof(buffer));
    }
    
    infile.close();
    outfile.close();
    
    cout << "Преобразование завершено. Результат записан в " << output << endl;
    
    return 0;
}
